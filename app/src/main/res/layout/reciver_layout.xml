<?xml version="1.0" encoding="utf-8"?>
<!-- REDESIGNED: Material You Receiver Message Bubble -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingHorizontal="12dp"
    android:paddingVertical="3dp">

    <!-- Receiver avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/pro"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="bottom"
        android:src="@drawable/photocamera"
        app:civ_border_color="?attr/colorSecondary"
        app:civ_border_width="1.5dp" />

    <!-- Message bubble + timestamp column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:gravity="start"
        android:orientation="vertical">

        <!--
            FIX: MaterialCardView does NOT support cardCornerRadiusBottomStart etc.
            Use shapeAppearanceOverlay to set per-corner radii:
              topStart=20dp, topEnd=20dp, bottomEnd=20dp, bottomStart=4dp (sharp tail)
        -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:strokeWidth="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.ChitChat.ReceiverBubble">

            <TextView
                android:id="@+id/recivertextset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:maxWidth="240dp"
                android:padding="10dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Message text"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textSize="14sp" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/msgTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_regular"
            android:text="12:34"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>