<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════════╗
║  res/values/colors.xml  (SINGLE FILE — Light + Dark tokens)     ║
║                                                                  ║
║  HOW IT WORKS:                                                   ║
║  Light tokens  →  md_theme_*          (used by themes.xml)      ║
║  Dark tokens   →  md_theme_dark_*     (used by values-night/    ║
║                                        themes.xml)              ║
║                                                                  ║
║  In  res/values/themes.xml  →  @color/md_theme_primary          ║
║  In  res/values-night/themes.xml  →  @color/md_theme_dark_primary║
║                                                                  ║
║  No values-night/colors.xml needed. One file does it all.       ║
╚══════════════════════════════════════════════════════════════════╝
-->
<resources>

    <!-- ════════════════════════════════════════════════════
         LIGHT MODE TOKENS   (prefix: md_theme_)
         Seed color: Teal-Green #1A6B45
         ════════════════════════════════════════════════════ -->

