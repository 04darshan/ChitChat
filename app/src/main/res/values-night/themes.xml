<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════════╗
║  res/values-night/themes.xml  (DARK MODE)                       ║
║  Place this file at:                                             ║
║    app/src/main/res/values-night/themes.xml                      ║
║                                                                  ║
║  Android automatically uses this folder when the device is       ║
║  in dark mode (Settings → Display → Dark theme).                 ║
║                                                                  ║
║  Colours come from  res/values-night/colors.xml  (see below).   ║
╚══════════════════════════════════════════════════════════════════╝
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════
         MAIN APPLICATION THEME  (Dark)
         Same structure as light; color tokens automatically resolve
         to the dark palette defined in values-night/colors.xml.
         ═══════════════════════════════════════════════════ -->
    <style name="Theme.ChitChat" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Dark palette — tokens from res/values/colors.xml (md_theme_dark_* prefix) -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimaryContainer</item>

        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_dark_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_dark_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_dark_onSecondaryContainer</item>

        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorSurfaceContainer">@color/md_theme_dark_surfaceContainer</item>
        <item name="colorSurfaceContainerLow">@color/md_theme_dark_surfaceContainerLow</item>
        <item name="colorSurfaceContainerHigh">@color/md_theme_dark_surfaceContainerHigh</item>

        <item name="colorError">@color/md_theme_dark_error</item>
        <item name="colorOnError">@color/md_theme_dark_onError</item>
        <item name="colorErrorContainer">@color/md_theme_dark_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_dark_onErrorContainer</item>

        <item name="colorOutline">@color/md_theme_dark_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_dark_outlineVariant</item>

        <!-- Dark surface → white status bar icons -->

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <item name="textAppearanceDisplayLarge">@style/TextAppearance.ChitChat.DisplayLarge</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.ChitChat.HeadlineLarge</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.ChitChat.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.ChitChat.TitleMedium</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.ChitChat.BodyMedium</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.ChitChat.LabelMedium</item>

    </style>

    <!-- Dark splash -->
    <style name="Theme.ChitChat.Splash" parent="Theme.ChitChat">
        <item name="android:windowBackground">@color/md_theme_dark_surface</item>
    </style>

    <!-- Dark dialog -->
    <style name="Theme.ChitChat.Dialog" parent="Theme.Material3.Dark.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowMinWidthMajor">90%</item>
        <item name="windowMinWidthMinor">90%</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <!-- Dark SearchView colours -->
    <style name="AppSearchViewStyle" parent="Widget.AppCompat.SearchView">
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Typography styles (same font; no change needed between modes) -->
    <style name="TextAppearance.ChitChat.DisplayLarge"
        parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/poppins_bold</item>
    </style>
    <style name="TextAppearance.ChitChat.HeadlineLarge"
        parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/poppins_bold</item>
    </style>
    <style name="TextAppearance.ChitChat.TitleLarge"
        parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins_bold</item>
    </style>
    <style name="TextAppearance.ChitChat.TitleMedium"
        parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/poppins_bold</item>
    </style>
    <style name="TextAppearance.ChitChat.BodyMedium"
        parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins_regular</item>
    </style>
    <style name="TextAppearance.ChitChat.LabelMedium"
        parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/poppins_regular</item>
    </style>

</resources>